{
  "name": "url-shortener",
  "version": "1.0.0",
  "description": "A URL shortener API built with Fastify and TDD",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "test": "jest --verbose",
    "test:integration": "jest --config jest.integration.config.ts --verbose",
    "test:integration:parallel": "jest --config jest.integration.parallel.config.ts --verbose",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@prisma/client": "6.19.3",
    "@sinclair/typebox": "^0.34.48",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.2",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.21",
    "@types/pg": "^8.20.0",
    "jest": "^30.0.0-beta.3",
    "prisma": "6.19.3",
    "ts-jest": "^29.3.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
