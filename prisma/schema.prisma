// Prisma schema for the URL shortener.
//
// Prisma reads this file to do two things: generate a fully typed client (the
// `generator` block) and create SQL migrations + connect at runtime (the
// `datasource` block). The schema is the single source of truth — the database
// shape and the TypeScript types are both derived from it, so they can never
// drift apart.
//
// Docs: https://pris.ly/d/prisma-schema

generator client {
  // `prisma-client-js` emits the classic client into node_modules, so the rest
  // of the code imports it as `@prisma/client`. We run `npx prisma generate`
  // (and `prisma migrate dev` runs it for us) to (re)build it after any change.
  provider = "prisma-client-js"
}

datasource db {
  // PostgreSQL, pointed at the Docker instance from chapter 9. The connection
  // string is read from the environment so the same schema targets the dev
  // database normally and the dedicated test database under Jest — never
  // hard-coded here, never committed.
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A single shortened URL.
///
/// `id` is an internal auto-incrementing integer — small, ordered, and never
/// exposed to clients. The *public* identifier is `shortCode`, which appears in
/// the short link and is what we look rows up by, so it gets a unique index.
///
/// The primary key is the composite `(id, shortCode)`, not `id` alone. The
/// underlying `urls` table is HASH-partitioned on `short_code` (see the
/// partitioning migration), and PostgreSQL requires every unique/PK on a
/// partitioned table to include the partition key. Prisma cannot express
/// partitioning, so the table is built by a hand-edited raw-SQL migration; the
/// model only needs to agree on the key shape. `shortCode` stays `@unique`, so
/// `findByCode`, the collision retry, and every endpoint behave exactly as
/// before — only the physical storage changed.
model Url {
  id          Int      @default(autoincrement())
  shortCode   String   @unique @map("short_code")
  originalUrl String   @map("original_url")
  clicks      Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  @@id([id, shortCode])

  // Map the model to a snake_case table name so the SQL stays idiomatic while
  // the TypeScript stays camelCase.
  @@map("urls")
}
