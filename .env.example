# Copy this file to `.env` (which is gitignored) and adjust if needed.
#
# These are LOCAL DEVELOPMENT credentials only — they match the defaults in
# docker-compose.yml so `docker compose up -d` and the app/tests line up out
# of the box. Never commit real secrets.

# --- Postgres container settings (read by docker-compose.yml) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=urlshortener
# Host port (mapped to the container's 5432). 5433 avoids clashing with a
# Postgres already running on the default 5432.
POSTGRES_PORT=5433

# --- Application / test connection strings ---
# DATABASE_URL is read in three places:
#   - src/config.ts (validated at startup; required, must be a URI),
#   - src/db/pool.ts (the pg Pool) when NODE_ENV is not "test", and
#   - prisma/schema.prisma's datasource, used by `prisma migrate` and the
#     generated Prisma client at runtime.
# Dev database — the default target.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/urlshortener

# Dedicated test database — used when NODE_ENV === "test" (Jest sets this).
# It is a SEPARATE database on the same instance so tests can wipe data freely.
# The integration setup points Prisma's DATABASE_URL at this value during tests,
# and applies the migrations here via `prisma migrate deploy` before the suite.
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5433/urlshortener_test

# --- Application configuration (validated by src/config.ts at startup) ---
# All of these are optional — sensible defaults are applied if unset. Invalid
# values (non-numeric PORT, malformed BASE_URL, unknown NODE_ENV) fail fast at
# boot with a clear message instead of starting in a broken state.

# Port the HTTP server listens on. Default: 3000.
PORT=3000

# Public base URL used to build the `shortUrl` returned by the API. Set this to
# your real host in production (e.g. https://sho.rt). Default: http://localhost:3000.
BASE_URL=http://localhost:3000

# Runtime environment: development | test | production. Default: development.
NODE_ENV=development
